{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "extraEnv": {
            "SQLX_OFFLINE": "true",
          },
        },
        "server": {
          "extraEnv": {
            "SQLX_OFFLINE": "true",
          },
        },
        "runnables": {
          "extraEnv": {
            "SQLX_OFFLINE": "true",
          },
        },
      },
    },
  },
  "languages": {
    "SQL": {
      "language_servers": ["sqruff"],
      "formatter": { "language_server": { "name": "sqruff" } },
    },
    "Svelte": {
      "inlay_hints": {
        "show_type_hints": false,
      },
    },
  },
}
