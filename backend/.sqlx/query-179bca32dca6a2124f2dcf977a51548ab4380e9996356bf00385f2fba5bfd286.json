  "query": "SELECT q.quest_id, q.title, q.summary, q.details, q.techs, q.status as \"status: QuestStatus\", q.created_at as quest_created_at, u.user_id, u.github_id, u.handle, u.created_at as user_created_at FROM quests q JOIN users u ON u.user_id = q.poster_id\n        WHERE q.quest_id=$1",
